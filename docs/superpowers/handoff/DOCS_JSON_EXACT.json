{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "WednesdayAI",
  "description": "The AI platform that stays yours. Documentation for administrators, users, and developers.",
  "colors": {
    "primary": "#6366f1",
    "light": "#818cf8",
    "dark": "#4f46e5"
  },
  "fonts": {
    "heading": {
      "family": "Space Grotesk"
    },
    "body": {
      "family": "Inter"
    }
  },
  "logo": {
    "light": "/assets/logo-light.svg",
    "dark": "/assets/logo-dark.svg"
  },
  "favicon": "/assets/favicon.svg",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "codeblocks": "dark"
  },
  "background": {
    "color": {
      "dark": "#0f172a"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Administrators",
        "icon": "server-cog",
        "groups": [
          {
            "group": "Getting started",
            "icon": "rocket",
            "pages": [
              "admin/getting-started"
            ]
          },
          {
            "group": "Gateway configuration",
            "icon": "sliders-horizontal",
            "pages": [
              "admin/gateway/configuration",
              "admin/gateway/authentication",
              "admin/gateway/remote-access",
              "admin/gateway/logging",
              "admin/gateway/health-checks"
            ]
          },
          {
            "group": "Channels",
            "icon": "messages-square",
            "pages": [
              "admin/channels/index",
              "admin/channels/whatsapp",
              "admin/channels/telegram",
              "admin/channels/discord",
              "admin/channels/slack",
              "admin/channels/signal"
            ]
          },
          {
            "group": "Security",
            "icon": "shield-check",
            "pages": [
              "admin/security"
            ]
          },
          {
            "group": "Maintenance",
            "icon": "wrench",
            "pages": [
              "admin/upgrading",
              "admin/troubleshooting"
            ]
          }
        ]
      },
      {
        "tab": "Users",
        "icon": "user-round",
        "groups": [
          {
            "group": "Getting started",
            "icon": "rocket",
            "pages": [
              "users/what-is-wednesdayai",
              "users/pairing/first-channel",
              "users/pairing/whatsapp",
              "users/pairing/telegram",
              "users/pairing/discord"
            ]
          },
          {
            "group": "Talking to your AI",
            "icon": "message-circle",
            "pages": [
              "users/messaging",
              "users/commands"
            ]
          },
          {
            "group": "Built-in tools",
            "icon": "wand-sparkles",
            "pages": [
              "users/tools/index"
            ]
          },
          {
            "group": "Help",
            "icon": "life-buoy",
            "pages": [
              "users/troubleshooting"
            ]
          }
        ]
      },
      {
        "tab": "Developers",
        "icon": "code",
        "groups": [
          {
            "group": "Getting started",
            "icon": "rocket",
            "pages": [
              "developers/overview",
              "developers/plugins/your-first-plugin"
            ]
          },
          {
            "group": "Extension points",
            "icon": "puzzle",
            "pages": [
              "developers/hooks",
              "developers/channel-adapters",
              "developers/agent-tools"
            ]
          },
          {
            "group": "AI providers",
            "icon": "brain-circuit",
            "pages": [
              "developers/providers/index",
              "developers/providers/anthropic",
              "developers/providers/openai",
              "developers/providers/google",
              "developers/providers/ollama",
              "developers/providers/openrouter",
              "developers/providers/litellm"
            ]
          },
          {
            "group": "SDK reference",
            "icon": "boxes",
            "pages": [
              "developers/sdk/index"
            ]
          },
          {
            "group": "Contributing",
            "icon": "git-pull-request",
            "pages": [
              "developers/contributing"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "icon": "book-open",
        "groups": [
          {
            "group": "Reference",
            "icon": "book-open",
            "pages": [
              "reference/config",
              "reference/cli",
              "reference/hooks-catalogue",
              "reference/api"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Changelog",
          "icon": "megaphone",
          "href": "https://github.com/ExpansionX/WednesdayAI-core/blob/main/CHANGELOG.md"
        },
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/ExpansionX/WednesdayAI-core"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/ExpansionX/WednesdayAI-core",
        "icon": "github"
      },
      {
        "label": "Discord",
        "href": "https://discord.gg/wednesdayai",
        "icon": "discord"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get started",
      "href": "/admin/getting-started"
    }
  },
  "search": {
    "prompt": "Search WednesdayAI docs..."
  },
  "seo": {
    "indexing": "navigable"
  }
}
